<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="50dp">

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/illustration_group"
        android:backgroundTint="#4A4947"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/byemsg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/libre_baskerville_family"
        android:text="You are Leaving, are you"
        android:textFontWeight="700"
        android:textColor="#B17457"
        android:textSize="20dp"
        android:layout_gravity="center"
        android:layout_marginBottom="5dp"/>

    <TextView
        android:id="@+id/byemsg1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/libre_baskerville_family"
        android:text="sure you want to go?"
        android:textColor="#B17457"
        android:textSize="20dp"
        android:textFontWeight="700"
        android:layout_gravity="center"
        android:layout_marginBottom="30dp"/>
    
   <com.google.android.material.button.MaterialButton
       android:id="@+id/btnCancel"
       style="@style/MaterialButton.Secondary"
       android:layout_width="match_parent"
       android:layout_height="wrap_content"
       android:layout_marginBottom="10dp"
       android:text="No, Keep Organizing"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnYesLogout"
        style="@style/MaterialButton.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:backgroundTint="#808080"
        android:text="Yes, log me out" />

