<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/developer_page_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    tools:context=".ui.activity.MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="10dp"
        android:paddingTop="12dp"
        android:background="@color/background">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/schedule_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?attr/actionBarSize"
            app:titleTextAppearance="@style/App.ToolBar.Title"
            app:title="Schedule"
            app:menu="@menu/tool_bar_schedule_menu">
        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <com.alamkanak.weekview.WeekView
        android:id="@+id/weekView"
        android:layout_marginStart="4dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:defaultEventColor="@color/secondaryContainer"
        app:eventTextColor="@color/onSecondaryContainer"
        app:timeColumnTextSize="12sp"
        app:hourHeight="60dp"
        app:timeColumnPadding="8dp"
        app:timeColumnTextColor="@color/black"
        app:timeColumnBackgroundColor="#ECE9E3"
        app:headerPadding="12dp"
        app:columnGap="8dp"
        app:numberOfVisibleDays="3"
        app:headerBackgroundColor="@color/background"
        app:dayBackgroundColor="#ECE9E3"
        app:todayBackgroundColor="@color/black"
        app:showNowLine="true"
        app:nowLineColor="@color/secondary"
        app:nowLineStrokeWidth="2dp"/>

</LinearLayout>