<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Archives" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
<!--        <item name="colorPrimary">@color/dirty_white</item>-->
    </style>

    <style name="Theme.Archives" parent="Base.Theme.Archives" />

    <style name="HomeDateMaterialCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeColor">@color/black</item>
        <item name="strokeWidth">2dp</item>
    </style>

    <style name="KanbanBoardToggleButton" parent="Widget.Material3.Button">
        <item name="android:padding">1dp</item>
        <item name="android:layout_margin">0dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/black</item>
    </style>

    <style name="KanbanBoardAddTaskButton" parent="Widget.Material3.Button.TextButton.Icon">
        <item name="backgroundTint">@color/coal</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:padding">4dp</item>
        <item name="cornerRadius">6dp</item>
        <item name="iconTint">@color/white</item>
        <item name="android:textColor">@color/white</item>
    </style>
    
    <style name="MaterialButton.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/coal</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="MaterialButton.Secondary" parent="Widget.Material3.Button.OutlinedButton.Icon">
        <item name="backgroundTint">@color/dirty_white</item>
        <item name="android:textColor">@color/coal</item>
        <item name="strokeColor">@color/coal</item>
        <item name="strokeWidth">2dp</item>
        <item name="iconTint">@color/coal</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="MaterialButton.Tertiary" parent="Widget.Material3.Button.OutlinedButton.Icon">
        <item name="backgroundTint">@color/brown</item>
        <item name="android:textColor">@color/white</item>
        <item name="strokeColor">@color/brown</item>
        <item name="iconTint">@color/coal</item>
        <item name="cornerRadius">12dp</item>
    </style>

</resources>