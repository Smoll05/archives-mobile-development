<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="MaterialButton.Base" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="strokeWidth">2dp</item>
        <item name="strokeColor">@color/black</item>
    </style>

    <style name="HomeDateMaterialCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeColor">@color/black</item>
        <item name="strokeWidth">2dp</item>
    </style>

    <!-- Primary Button -->
    <style name="MaterialButton.Primary" parent="MaterialButton.Base">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/onPrimary</item>
    </style>

    <!-- Primary Container Button -->
    <style name="MaterialButton.PrimaryContainer" parent="MaterialButton.Base">
        <item name="backgroundTint">@color/primaryContainer</item>
        <item name="android:textColor">@color/onPrimaryContainer</item>
    </style>

    <!-- Secondary Button -->
    <style name="MaterialButton.Secondary" parent="MaterialButton.Base">
        <item name="backgroundTint">@color/secondary</item>
        <item name="android:textColor">@color/onSecondary</item>
    </style>

    <!-- Secondary Container Button -->
    <style name="MaterialButton.SecondaryContainer" parent="MaterialButton.Base">
        <item name="backgroundTint">@color/secondaryContainer</item>
        <item name="android:textColor">@color/onSecondaryContainer</item>
    </style>

    <!-- Tertiary Button -->
    <style name="MaterialButton.Tertiary" parent="MaterialButton.Base">
        <item name="backgroundTint">@color/tertiary</item>
        <item name="android:textColor">@color/onTertiary</item>
    </style>

    <!-- Tertiary Container Button -->
    <style name="MaterialButton.TertiaryContainer" parent="MaterialButton.Base">
        <item name="backgroundTint">@color/tertiaryContainer</item>
        <item name="android:textColor">@color/onTertiaryContainer</item>
    </style>

    <!-- Error Button -->
    <style name="MaterialButton.Error" parent="MaterialButton.Base">
        <item name="backgroundTint">@color/error</item>
        <item name="android:textColor">@color/onError</item>
    </style>

    <!-- Error Container Button -->
    <style name="MaterialButton.ErrorContainer" parent="MaterialButton.Base">
        <item name="backgroundTint">@color/errorContainer</item>
        <item name="android:textColor">@color/onErrorContainer</item>
    </style>

    <!-- Error Outlined Button -->
    <style name="MaterialButton.ErrorOutlined" parent="MaterialButton.Base">
        <item name="strokeColor">@color/error</item>
        <item name="backgroundTint">@color/background</item>
        <item name="android:textColor">@color/error</item>
    </style>

    <!-- Bottom Navigation Bar Style -->
    <style name="BottomNavStyle" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/background</item>
        <item name="elevation">0dp</item>
        <item name="color">@color/primaryContainer</item>
        <item name="itemIconTint">@color/onSurface</item>
        <item name="itemTextColor">@color/onSurface</item>
        <item name="itemActiveIndicatorStyle">@style/CustomActiveIndicator</item>
    </style>

    <style name="CustomActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/surfaceVariant</item>
    </style>

    <style name="KanbanBoardToggleButton" parent="Widget.Material3.Button">
        <item name="android:padding">1dp</item>
        <item name="android:layout_margin">0dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/black</item>
    </style>

    <style name="KanbanBoardAddTaskButton" parent="Widget.Material3.Button.TextButton.Icon">
        <item name="backgroundTint">@color/tertiaryContainer</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:padding">4dp</item>
        <item name="cornerRadius">6dp</item>
        <item name="iconTint">@color/white</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="App.ToolBar.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/libre_baskerville_italic</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="App.ToolBar.Subtitle" parent="TextAppearance.Material3.ActionBar.Subtitle">
        <item name="fontFamily">@font/inter</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="App.ToolBar.MiniTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/inter</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="App.Settings.Preference.Card" parent="Widget.Material3.CardView.Outlined">
        <item name="strokeColor">@color/black</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">#dedbd3</item>
        <item name="cornerRadius">50dp</item>
    </style>

    <style name="App.Settings.Preference.Text" parent="TextAppearance.AppCompat.Body1">
        <item name="color">@color/onPrimary</item>
    </style>

    <!-- Switch -->
    <style name="Widget.App.Switch" parent="Widget.Material3.CompoundButton.Switch">
        <item name="materialThemeOverlay">@style/ThemeOverlay.App.Switch</item>
        <item name="thumbTint">@color/white</item>
    </style>

    <style name="ThemeOverlay.App.Switch" parent="">
        <item name="colorPrimaryContainer">#5dc880</item>
        <item name="colorPrimary">#5dc880</item>
    </style>

    <!--Edit Text Style-->
    <style name="Archives.EditText.Style" parent="Widget.Material3.TextInputEditText.FilledBox">
        <item name="android:background">@drawable/shape_edittext_border</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">12dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/black</item>
        <item name="fontFamily">@font/inter</item>
    </style>

    <style name="Archives.Counter.TextAppearance" parent="TextAppearance.Material3.BodySmall">
        <item name="android:padding">0dp</item>
        <item name="android:layout_margin">0dp</item>
        <item name="android:textSize">8sp</item>
        <item name="fontFamily">@font/inter</item>
    </style>

    <style name="Archives.Error.TextAppearance" parent="TextAppearance.Material3.BodySmall">
        <item name="android:padding">0dp</item>
        <item name="android:layout_margin">0dp</item>
        <item name="android:textSize">12sp</item>
        <item name="fontFamily">@font/inter</item>
    </style>

</resources>