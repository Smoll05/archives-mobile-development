<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="MaterialButton.Base" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="strokeWidth">2dp</item>
        <item name="strokeColor">@color/black</item>
    </style>

    <style name="HomeDateMaterialCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeColor">@color/black</item>
        <item name="strokeWidth">2dp</item>
    </style>

    <!-- Primary Button -->
    <style name="MaterialButton.Primary" parent="MaterialButton.Base">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/onPrimary</item>
    </style>

    <!-- Primary Container Button -->
    <style name="MaterialButton.PrimaryContainer" parent="MaterialButton.Base">
        <item name="backgroundTint">@color/primaryContainer</item>
        <item name="android:textColor">@color/onPrimaryContainer</item>
    </style>

    <!-- Secondary Button -->
    <style name="MaterialButton.Secondary" parent="MaterialButton.Base">
        <item name="backgroundTint">@color/secondary</item>
        <item name="android:textColor">@color/onSecondary</item>
    </style>

    <!-- Secondary Container Button -->
    <style name="MaterialButton.SecondaryContainer" parent="MaterialButton.Base">
        <item name="backgroundTint">@color/secondaryContainer</item>
        <item name="android:textColor">@color/onSecondaryContainer</item>
    </style>

    <!-- Tertiary Button -->
    <style name="MaterialButton.Tertiary" parent="MaterialButton.Base">
        <item name="backgroundTint">@color/tertiary</item>
        <item name="android:textColor">@color/onTertiary</item>
    </style>

    <!-- Tertiary Container Button -->
    <style name="MaterialButton.TertiaryContainer" parent="MaterialButton.Base">
        <item name="backgroundTint">@color/tertiaryContainer</item>
        <item name="android:textColor">@color/onTertiaryContainer</item>
    </style>

    <!-- Bottom Navigation Bar Style -->
    <style name="BottomNavStyle" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/background</item>
        <item name="elevation">0dp</item>
        <item name="color">@color/primaryContainer</item>
        <item name="itemIconTint">@color/onSurface</item>
        <item name="itemTextColor">@color/onSurface</item>
        <item name="itemActiveIndicatorStyle">@style/CustomActiveIndicator</item>
    </style>

    <style name="CustomActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/surfaceVariant</item>
    </style>

    <style name="KanbanBoardToggleButton" parent="Widget.Material3.Button">
        <item name="android:padding">1dp</item>
        <item name="android:layout_margin">0dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/black</item>
    </style>

    <style name="KanbanBoardAddTaskButton" parent="Widget.Material3.Button.TextButton.Icon">
        <item name="backgroundTint">@color/tertiaryContainer</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:padding">4dp</item>
        <item name="cornerRadius">6dp</item>
        <item name="iconTint">@color/white</item>
        <item name="android:textColor">@color/white</item>
    </style>

</resources>